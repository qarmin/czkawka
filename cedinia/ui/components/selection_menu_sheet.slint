import { Fonts } from "../globals/fonts.slint";
import { CediniaColors } from "../globals/colors.slint";
import { AppState } from "../globals/app_state.slint";
import { Translations } from "../globals/translations.slint";
import { ScrimDialog } from "scrim_dialog.slint";
import { TouchButton } from "buttons/touch_button.slint";

export component SelectionMenuSheet inherits ScrimDialog {
    in-out property <bool> is_grouped: true;
    in-out property <bool> has_size_select: true;
    in-out property <bool> has_resolution_select: true;
    callback closed;

    card_max_width: 300px;
    card_radius: 14px;
    card_padding: 12px;
    card_spacing: 6px;
    shadow_color: CediniaColors.shadow_lg;
    dismissed => { root.closed(); }

    Text {
        text: Translations.selection_popup_title_text;
        color: CediniaColors.text_secondary;
        font-size: Fonts.body;
        font-weight: Fonts.bold;
        letter-spacing: 0.5px;
        horizontal-alignment: TextHorizontalAlignment.center;
    }

    TouchButton {
        label: Translations.select_all_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.text_primary;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_all(); root.closed(); }
    }

    if root.is_grouped : TouchButton {
        label: Translations.select_except_one_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.accent_light;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_all_except_one(); root.closed(); }
    }

    if root.has_size_select : TouchButton {
        label: Translations.select_except_largest_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.accent_light;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_all_except_largest(); root.closed(); }
    }

    if root.has_size_select : TouchButton {
        label: Translations.select_except_smallest_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.accent_light;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_all_except_smallest(); root.closed(); }
    }

    if root.has_size_select : TouchButton {
        label: Translations.select_largest_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.accent_light;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_largest_per_group(); root.closed(); }
    }

    if root.has_size_select : TouchButton {
        label: Translations.select_smallest_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.accent_light;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_smallest_per_group(); root.closed(); }
    }

    if root.has_resolution_select : TouchButton {
        label: Translations.select_except_highest_res_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.accent_light;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_all_except_highest_resolution(); root.closed(); }
    }

    if root.has_resolution_select : TouchButton {
        label: Translations.select_except_lowest_res_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.accent_light;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_all_except_lowest_resolution(); root.closed(); }
    }

    if root.has_resolution_select : TouchButton {
        label: Translations.select_highest_res_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.accent_light;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_highest_resolution_per_group(); root.closed(); }
    }

    if root.has_resolution_select : TouchButton {
        label: Translations.select_lowest_res_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.accent_light;
        horizontal-stretch: 1.0;
        clicked => { AppState.select_lowest_resolution_per_group(); root.closed(); }
    }

    TouchButton {
        label: Translations.invert_selection_text;
        min_h: 44px;
        bg: CediniaColors.bg_surface;
        fg: CediniaColors.text_secondary;
        horizontal-stretch: 1.0;
        clicked => { AppState.invert_selection(); root.closed(); }
    }

    TouchButton {
        label: Translations.close_text;
        min_h: 40px;
        bg: CediniaColors.bg_elevated;
        fg: CediniaColors.text_disabled;
        horizontal-stretch: 1.0;
        clicked => { root.closed(); }
    }
}
