<?xml version="1.0" encoding="utf-8"?>
<!-- Mirrors [package.metadata.android] in cedinia/Cargo.toml.
     Keep in sync when adding permissions or changing activity config. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Full external storage access (needed to scan /sdcard root on Android 11+) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <!-- Required on Android 13+ (API 33) to post system notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name="android.app.NativeActivity"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|navigation|uiMode|screenLayout|locale|density|fontScale"
            android:launchMode="singleTop"
            android:exported="true">

            <!-- Tells NativeActivity which .so to load -->
            <meta-data
                android:name="android.app.lib_name"
                android:value="cedinia" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
