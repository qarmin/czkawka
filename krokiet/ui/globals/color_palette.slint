import { Settings } from "settings.slint";

export global ColorPalette {
    // Tabs at left side
    in-out property <color> tab_selected_color: Settings.dark_theme ? #353535 : #5e5e5e;
    in-out property <color> tab_hovered_color: Settings.dark_theme ? #49494926 : #80808014;
    // ListView
    in-out property <color> list_view_item_color: Settings.dark_theme ? #222222 : #f8fafc;
    in-out property <color> list_view_item_hovered_color: Settings.dark_theme ? #333333 : #dce5ef;
    in-out property <color> list_view_item_selected_color: Settings.dark_theme ? #444444 : #c5d5e6;
    in-out property <color> list_view_item_selected_hovered_color: Settings.dark_theme ? #555555 : #b5c8dc;

    in-out property <color> list_view_header_color: Settings.dark_theme ? #111111 : #d5dfe9;
    in-out property <color> list_view_clicked_header_color: Settings.dark_theme ? #1a1a1a : #c8d4e0;
    
    // Popup
    in-out property <color> popup_background: Settings.dark_theme ? #353535 : #cecece;
    in-out property <color> popup_background_border: Settings.dark_theme ? #222222 : #808080;
    in-out property <color> popup_background_title_line: Settings.dark_theme ? #252525 : #9e9e9e;
    in-out property <color> popup_border_color: Settings.dark_theme ? #000000 : #808080;

    in-out property <color> line_item_color: Settings.dark_theme ? #222222 : #dddddd;

    in-out property <color> remove_item_color_button: Settings.dark_theme ? #222222 : #dddddd;

    in-out property <color> hint_color: Settings.dark_theme ? #888888 : #888888;

    in-out property <color> compare_left_value_color: Settings.dark_theme ? #6699cc : #224488;
    in-out property <color> compare_right_value_color: Settings.dark_theme ? #cc9966 : #885522;
    in-out property <color> compare_divider_color: Settings.dark_theme ? #444444 : #aaaaaa;
    in-out property <color> compare_info_background: Settings.dark_theme ? #222222 : #d8d8d8;
    in-out property <color> compare_info_border: Settings.dark_theme ? #444444 : #bbbbbb;
    in-out property <color> compare_loading_card_background: Settings.dark_theme ? #2a2a2a : #f4f4f4;

    public pure function get_listview_color(selected: bool, hovered: bool) -> color {
        if (selected) {
            return hovered ? self.list_view_item_selected_hovered_color : self.list_view_item_selected_color;
        } else {
            return hovered ? self.list_view_item_hovered_color : self.list_view_item_color;
        }
    }
    public pure function get_listview_color_with_header(selected: bool, hovered: bool, header: bool) -> color {
        if (header) {
            return selected ? self.list_view_clicked_header_color : self.list_view_header_color;
        } else {
            return self.get_listview_color(selected, hovered);
        }
    }
}
