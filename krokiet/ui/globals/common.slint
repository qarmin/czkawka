export enum ActiveTab {
    DuplicateFiles,
    EmptyFolders,
    BigFiles,
    EmptyFiles,
    TemporaryFiles,
    SimilarImages,
    SimilarVideos,
    SimilarMusic,
    InvalidSymlinks,
    BrokenFiles,
    BadExtensions,
    BadNames,
    ExifRemover,
    VideoOptimizer,
    Settings,
    About
}

export enum PopupRequest {
    Delete,
    Trash,
    Move,
    CleanExif,
    OptimizeVideo,
    RenameBadExtension,
    RenameBadFileName,
    Symlink,
    Hardlink,
    Save
}

export enum SortColumnMode {
    None, // None is default mode, is set when starting scan and cannot be restored by user
    Descending,
    Ascending
}

export enum TypeOfOpenedItem {
    CurrentItem,
    ParentItem
}

export struct ProgressToSend {
    current_progress: int,
    current_progress_size: int,
    all_progress: int,
    step_name: string,
}

export struct SingleMainListModel {
    checked: bool,
    header_row: bool,
    filled_header_row: bool,
    focused_row: bool,
    val_str: [string],
    val_int: [int]
}

export enum BottomPanelVisibility {
    NotVisible,
    TextErrors,
    Directories
}

export struct IncludedPathsModel {
    path: string,
    referenced_path: bool,
    focused_row: bool,
}

export struct ExcludedPathsModel {
    path: string,
    focused_row: bool,
}

export enum SelectMode {
    SelectAll,
    UnselectAll,
    InvertSelection,
    InvertSelectionInGroup,
    SelectTheBiggestSize,
    SelectTheBiggestResolution,
    SelectTheSmallestSize,
    SelectTheSmallestResolution,
    SelectNewest,
    SelectOldest,
    SelectShortestPath,
    SelectLongestPath,
    SelectAllExceptBiggestSize,
    SelectAllExceptSmallestSize,
    SelectAllExceptBiggestResolution,
    SelectAllExceptSmallestResolution,
    SelectAllExceptNewest,
    SelectAllExceptOldest,
    SelectAllExceptLongestPath,
    SelectAllExceptShortestPath,
    SelectCustom,
}

export struct SelectModel {
    data: SelectMode,
    name: string
}

export enum ColumnType {
    Str,
    Int,
    Date,
    FullPath,
}

export struct CustomSelectColumnModel {
    column_name: string,
    column_idx: int,
    column_type: ColumnType,
    // For ColumnType.Int: true means the value is stored as a (Part1, Part2) u64 pair
    // in val_int (e.g. Size, Bitrate); false means it is a plain i32.
    is_pair: bool,
    enabled: bool,
    filter_value: string,
}

export enum SortMode {
    FullName,
    Focus,
    Reverse
}

export struct SortModel {
    data: SortMode,
    name: string
}

export struct CacheCleaningProgress {
    current_cache_file: int,
    total_cache_files: int,
    current_file_name: string,
    checked_entries: int,
    all_entries: int,
}

export struct CacheCleaningResult {
    processed_files_text: string,
    entries_stats_text: string,
    size_stats_text: string,
    time_text: string,
    errors_count: int,
    errors: string,
}

export struct CompareImageData {
    path: string,
    dir: string,
    name: string,
    size: string,
    resolution: string,
    modification_date: string,
    similarity: string,
    checked: bool,
    thumbnail: image,
    flat_idx: int,
}
